{{#if isRoomView}}
  <div class="page page_watch-party-room">
    <header id="header"></header>

    <main class="watch-room-page">
      {{#if loading}}
        <section class="watch-room-state">
          <h1 class="watch-room-state__title">Подключаем комнату</h1>
          <p class="watch-room-state__text">Получаем состояние совместного просмотра...</p>
        </section>
      {{else}}
        {{#if hasError}}
          <section class="watch-room-state watch-room-state_error">
            <h1 class="watch-room-state__title">{{errorTitle}}</h1>
            <p class="watch-room-state__text">{{errorText}}</p>
            <a class="watch-room-state__link" href="/watch-party" router-link>Вернуться в лобби</a>
          </section>
        {{else}}
          <section class="watch-room-shell">
            {{#if roomStatusMessage}}
              <div class="watch-room-shell__status watch-room-shell__status_{{roomStatusTone}}">
                {{roomStatusMessage}}
              </div>
            {{/if}}

            <div class="watch-room-shell__layout">
              <div class="watch-room-shell__main">
                <section class="watch-room-player-slot">
                  <div id="watch-party-room-player"></div>
                </section>

                <div class="watch-room-topbar">
                  <div class="watch-room-topbar__start">

                    <div class="watch-room-topbar__meta">
                      <div class="watch-room-topbar__headline">
                        <div class="watch-room-topbar__room">{{roomName}}</div>

                        {{#if liveLabel}}
                          <div class="watch-room-topbar__live">{{liveLabel}}</div>
                        {{/if}}
                      </div>

                      <div class="watch-room-topbar__details">
                        <span>{{movieTitle}}</span>
                        <span>{{privacyLabel}}</span>
                      </div>
                    </div>
                  </div>

                  <div class="watch-room-topbar__actions">

                    <button
                      class="watch-room-topbar__action watch-room-topbar__action_copy"
                      type="button"
                      data-action="copy-room-link"
                      data-link="{{inviteLink}}"
                    >
                      Пригласить
                    </button>
                  </div>
                </div>
              </div>
            </div>

            <div
              class="watch-room-drawer__backdrop{{#if isRoomPanelOpen}} is-visible{{/if}}"
              data-action="close-room-panel"
            ></div>

            <aside class="watch-room-drawer{{#if isRoomPanelOpen}} is-open{{/if}}">
              <div class="watch-room-drawer__header">
                <div class="watch-room-drawer__tabs">
                  <button
                    class="watch-room-drawer__tab{{#if isMembersPanel}} is-active{{/if}}"
                    type="button"
                    data-action="open-room-members"
                  >
                    Участники
                  </button>
                  <button
                    class="watch-room-drawer__tab{{#if isChatPanel}} is-active{{/if}}"
                    type="button"
                    data-action="open-room-chat"
                  >
                    Чат
                  </button>
                </div>

                <button
                  class="watch-room-drawer__close"
                  type="button"
                  data-action="close-room-panel"
                  aria-label="Закрыть панель"
                >
                  <span></span>
                  <span></span>
                </button>
              </div>

              <section
                class="watch-room-members watch-room-drawer__panel{{#if isMembersPanel}} is-active{{/if}}"
                {{#unless isMembersPanel}}hidden{{/unless}}
              >
                  <div class="watch-room-members__header">
                    <div class="watch-room-members__bar"></div>
                    <div class="watch-room-members__title">Участники</div>
                    <div class="watch-room-members__count">{{roomMembersCount}}</div>
                  </div>

                  <div class="watch-room-members__list">
                    {{#each members}}
                      <div class="watch-room-members__item">
                        <div
                          class="watch-room-members__avatar"
                          style="--watch-party-avatar-tint: {{this.avatarTint}}; --watch-party-status-color: {{this.statusColor}}"
                        >
                          {{this.initial}}
                          <div class="watch-room-members__status-dot"></div>
                        </div>

                        <div class="watch-room-members__identity">
                          <div class="watch-room-members__name{{#if this.statusText}} is-away{{/if}}">
                            {{this.name}}
                          </div>

                          <div class="watch-room-members__meta">
                            {{#if this.isHost}}
                              <span class="watch-room-members__host">хозяин</span>
                            {{/if}}
                            {{#if this.isYou}}
                              <span class="watch-room-members__you">вы</span>
                            {{/if}}
                            {{#if this.statusText}}
                              <span class="watch-room-members__state">{{this.statusText}}</span>
                            {{/if}}
                          </div>
                        </div>
                      </div>
                    {{/each}}
                  </div>
              </section>

              <section
                class="watch-room-chat watch-room-drawer__panel{{#if isChatPanel}} is-active{{/if}}"
                {{#unless isChatPanel}}hidden{{/unless}}
              >
                  <div class="watch-room-chat__header">
                    <div class="watch-room-chat__bar"></div>
                    <div class="watch-room-chat__title">Чат</div>
                  </div>

                  <div class="watch-room-chat__messages">
                    {{#each roomMessages}}
                      {{#if this.isBet}}
                        <article class="watch-room-chat__bet">
                          <div class="watch-room-chat__bet-head">
                            <div class="watch-room-chat__bet-author">
                              <span class="watch-room-chat__name">{{this.authorName}}</span>
                              <span class="watch-room-chat__time">{{this.timeLabel}}</span>
                            </div>
                            <span class="watch-room-chat__bet-badge">Ставка</span>
                          </div>

                          <div class="watch-room-chat__bet-question">{{this.question}}</div>
                          <div class="watch-room-chat__bet-meta">{{this.metaText}}</div>

                          <div class="watch-room-chat__bet-options">
                            {{#each this.options}}
                              <button
                                class="watch-room-chat__bet-option{{#if this.isSelected}} is-selected{{/if}}{{#if ../hasSelectedOption}} is-locked{{/if}}"
                                type="button"
                                data-action="select-bet-option"
                                data-message-id="{{../id}}"
                                data-option-id="{{this.id}}"
                                {{#if ../hasSelectedOption}}disabled{{/if}}
                              >
                                <span
                                  class="watch-room-chat__bet-option-bg"
                                  style="{{this.widthStyle}}"
                                ></span>
                                <span class="watch-room-chat__bet-option-inner">
                                  <span class="watch-room-chat__bet-option-label">{{this.label}}</span>
                                  <span class="watch-room-chat__bet-option-percent">{{this.percentLabel}}</span>
                                </span>
                              </button>
                            {{/each}}
                          </div>

                          <div class="watch-room-chat__bet-status">
                            <span>{{this.votersText}}</span>
                            <span>{{this.selectionText}}</span>
                          </div>
                        </article>
                      {{else}}
                        <div class="watch-room-chat__message">
                          <div
                            class="watch-room-chat__avatar"
                            style="--watch-party-avatar-tint: {{this.authorTint}}"
                          >
                            {{this.authorInitial}}
                          </div>

                          <div class="watch-room-chat__body">
                            <div class="watch-room-chat__line">
                              <span class="watch-room-chat__name">{{this.authorName}}</span>
                              <span class="watch-room-chat__time">{{this.timeLabel}}</span>
                            </div>

                            <div class="watch-room-chat__text">{{this.text}}</div>

                            {{#if this.reactionText}}
                              <div class="watch-room-chat__reaction">{{this.reactionText}}</div>
                            {{/if}}
                          </div>
                        </div>
                      {{/if}}
                    {{/each}}
                  </div>

                  {{#if isBetComposerOpen}}
                    <form class="watch-room-chat__bet-composer" data-action="create-bet">
                      <div class="watch-room-chat__composer-label">Новая ставка</div>
                      <input
                        class="watch-room-chat__composer-input"
                        type="text"
                        name="question"
                        placeholder="Вопрос — например: Кто победит?"
                      />

                      <div class="watch-room-chat__composer-options">
                        {{#each roomBetComposerOptions}}
                          <div class="watch-room-chat__composer-option">
                            <input
                              class="watch-room-chat__composer-input"
                              type="text"
                              name="option"
                              placeholder="Вариант {{this.index}}"
                            />
                            <button
                              class="watch-room-chat__composer-remove"
                              type="button"
                              data-action="remove-bet-option"
                              aria-label="Удалить вариант"
                              {{#unless this.canRemove}}disabled{{/unless}}
                            >
                              ×
                            </button>
                          </div>
                        {{/each}}
                      </div>

                      <div class="watch-room-chat__composer-actions">
                        <button
                          class="watch-room-chat__attach watch-room-chat__attach_secondary"
                          type="button"
                          data-action="add-bet-option"
                        >
                          Ещё вариант
                        </button>
                        <button
                          class="watch-room-chat__attach watch-room-chat__attach_secondary"
                          type="button"
                          data-action="close-bet-composer"
                        >
                          Отмена
                        </button>
                        <button class="watch-room-chat__attach watch-room-chat__attach_accent" type="submit">
                          Запустить
                        </button>
                      </div>
                    </form>
                  {{/if}}

                  <form class="watch-room-chat__form" data-action="send-chat-message">
                    <button
                      class="watch-room-chat__attach"
                      type="button"
                      data-action="toggle-bet-composer"
                      aria-label="Создать ставку через вложение"
                    >
                      <span></span>
                      <span></span>
                    </button>

                    <input
                      class="watch-room-chat__input"
                      type="text"
                      name="message"
                      placeholder="Написать в комнату..."
                      autocomplete="off"
                    />

                    <button class="watch-room-chat__send" type="submit">Отправить</button>
                  </form>
              </section>
            </aside>
          </section>
        {{/if}}
      {{/if}}
    </main>
  </div>
{{else}}
  <div class="page page_watch-party">
    <header id="header"></header>

    <main class="watch-party-page">
      <div class="watch-party-page__inner">
        {{#if isLoading}}
          <div class="watch-party__status" role="status">
            Загружаем данные комнаты...
          </div>
        {{/if}}

        {{#if errorMessage}}
          <div class="watch-party__status watch-party__status--error" role="alert">
            <span>{{errorMessage}}</span>
            <button
              class="watch-party__button watch-party__button--ghost"
              type="button"
              data-action="retry-overview"
            >
              Повторить
            </button>
          </div>
        {{/if}}

        {{#if statusMessage}}
          <div
            class="watch-party__status watch-party__status--{{statusTone}}"
            role="status"
          >
            {{statusMessage}}
          </div>
        {{/if}}

        <section class="watch-party__hero">
          <div class="watch-party__hero-copy">
            <div class="watch-party__eyebrow">{{heroEyebrow}}</div>
            <h1 class="watch-party__title">{{heroTitle}}</h1>
            <p class="watch-party__subtitle">{{heroSubtitle}}</p>
            <p class="watch-party__description">{{heroDescription}}</p>

            <div class="watch-party__hero-actions">
              <button
                class="watch-party__button watch-party__button--accent"
                type="button"
                data-action="scroll-to-section"
                data-target="create-room-section"
              >
                Создать комнату
              </button>
              <button
                class="watch-party__button watch-party__button--ghost"
                type="button"
                data-action="scroll-to-section"
                data-target="join-room-section"
              >
                Войти по ссылке
              </button>
            </div>
          </div>

          <div class="watch-party__poster-stack" aria-label="Подборка для совместного просмотра">
            {{#each heroPosters}}
              <article class="watch-party__poster-card">
                <img src="{{this.imageUrl}}" alt="{{this.title}}" />
                <div class="watch-party__poster-overlay">
                  <span class="watch-party__poster-chip">{{this.label}}</span>
                  <span class="watch-party__poster-play" aria-hidden="true"></span>
                </div>
              </article>
            {{/each}}
          </div>
        </section>

        <section class="watch-party__section" id="create-room-section">
          <div class="watch-party__section-heading">
            <div>
              <p class="watch-party__section-kicker">Быстрый старт</p>
              <h2 class="watch-party__section-title">Настройте комнату под свой сеанс</h2>
            </div>
          </div>

          <div class="watch-party__actions-grid">
            <article class="watch-party__action-card watch-party__action-card--accent">
              <div class="watch-party__action-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <circle cx="12" cy="12" r="9"></circle>
                  <path d="M12 8v8M8 12h8"></path>
                </svg>
              </div>
              <h3>Создать комнату</h3>
              <p>
                Укажите название, выберите режим доступа и сразу переходите
                в комнату по адресу вида <strong>/watch-party/id...</strong>.
              </p>

              <form class="watch-party__form" data-action="create-room">
                <label class="watch-party__field">
                  <span>Название комнаты</span>
                  <input
                    class="watch-party__input"
                    name="roomName"
                    type="text"
                    placeholder="Например, Пятничный кинопросмотр"
                  />
                </label>

                <label class="watch-party__field">
                  <span>Доступ</span>
                  <select class="watch-party__input watch-party__input--select" name="visibility">
                    {{#each visibilityOptions}}
                      <option value="{{this.value}}"{{#if this.selected}} selected{{/if}}>
                        {{this.label}}
                      </option>
                    {{/each}}
                  </select>
                </label>

                <button
                  class="watch-party__button watch-party__button--accent watch-party__button--full"
                  type="submit"
                >
                  Создать комнату
                </button>
              </form>
            </article>

            <article
              class="watch-party__action-card watch-party__action-card--muted"
              id="join-room-section"
            >
              <div class="watch-party__action-icon watch-party__action-icon--muted" aria-hidden="true">
                <svg viewBox="0 0 24 24">
                  <path d="M10 7H6a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h4"></path>
                  <path d="M13 8l5 4-5 4"></path>
                  <path d="M18 12h-9"></path>
                </svg>
              </div>
              <h3>Войти по ссылке</h3>
              <p>
                Если друг уже создал комнату, вставьте приглашение и переходите
                прямо в нужный URL.
              </p>

              <form class="watch-party__join-form" data-action="join-room">
                <label class="watch-party__field watch-party__field--grow">
                  <span>Ссылка-приглашение</span>
                  <input
                    class="watch-party__input"
                    name="inviteLink"
                    type="url"
                    placeholder="https://vkino.ru/watch-party/id31"
                  />
                </label>
                <button class="watch-party__button watch-party__button--ghost" type="submit">
                  Войти
                </button>
              </form>
            </article>
          </div>
        </section>

        <section class="watch-party__section">
          <div class="watch-party__section-heading">
            <div>
              <p class="watch-party__section-kicker">Сейчас онлайн</p>
              <h2 class="watch-party__section-title">Активные комнаты</h2>
            </div>
            {{#if featuredRooms.length}}
              <span class="watch-party__badge">{{featuredRoomsOnlineLabel}}</span>
            {{/if}}
          </div>

          {{#if featuredRooms.length}}
            <div class="watch-party__room-grid">
              {{#each featuredRooms}}
                <article class="watch-party__room-card">
                  <div class="watch-party__room-media">
                    <img src="{{this.imageUrl}}" alt="{{this.title}}" />

                    <div class="watch-party__room-tags">
                      {{#if this.isLive}}
                        <span class="watch-party__room-tag watch-party__room-tag--live">LIVE</span>
                      {{/if}}
                      <span class="watch-party__room-tag watch-party__room-tag--secondary">
                        {{this.membersCount}} участников
                      </span>
                    </div>

                    <span class="watch-party__poster-play watch-party__poster-play--solid" aria-hidden="true"></span>
                  </div>

                  <div class="watch-party__room-body">
                    <h3>{{this.title}}</h3>
                    <p class="watch-party__room-host">
                      Хозяин: <span>{{this.hostName}}</span>
                    </p>
                    <p class="watch-party__room-host">{{this.movieTitle}} · {{this.progressLabel}}</p>

                    <div class="watch-party__room-actions">
                      <button
                        class="watch-party__button watch-party__button--accent"
                        type="button"
                        data-action="join-featured-room"
                        data-room-id="{{this.id}}"
                      >
                        Присоединиться
                      </button>
                      <button
                        class="watch-party__button watch-party__button--ghost"
                        type="button"
                        data-action="copy-link"
                        data-link="{{this.roomHref}}"
                      >
                        Копировать ссылку
                      </button>
                    </div>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <div class="watch-party__empty-state">
              <h3>Данные недоступны</h3>
              <p>{{featuredRoomsUnavailableText}}</p>
            </div>
          {{/if}}
        </section>

        <section class="watch-party__section">
          <div class="watch-party__section-heading">
            <div>
              <p class="watch-party__section-kicker">Под рукой</p>
              <h2 class="watch-party__section-title">Мои комнаты</h2>
            </div>
            <span class="watch-party__badge">{{myRoomsCountLabel}}</span>
          </div>

          {{#if myRooms.length}}
            <div class="watch-party__my-rooms">
              {{#each myRooms}}
                <article class="watch-party__my-room-card">
                  <img
                    class="watch-party__my-room-thumb"
                    src="{{this.imageUrl}}"
                    alt="{{this.title}}"
                  />

                  <div class="watch-party__my-room-content">
                    <span
                      class="watch-party__state-badge watch-party__state-badge--{{this.statusTone}}"
                    >
                      {{this.statusLabel}}
                    </span>
                    <h3>{{this.title}}</h3>
                    <p>{{this.meta}}</p>

                    <div class="watch-party__room-actions">
                      <button
                        class="watch-party__button watch-party__button--accent"
                        type="button"
                        data-action="open-my-room"
                        data-room-id="{{this.id}}"
                      >
                        Войти
                      </button>
                      <button
                        class="watch-party__button watch-party__button--ghost"
                        type="button"
                        data-action="copy-link"
                        data-link="{{this.roomLink}}"
                      >
                        Поделиться
                      </button>
                      <button
                        class="watch-party__button watch-party__button--ghost watch-party__button--danger"
                        type="button"
                        data-action="delete-room"
                        data-room-id="{{this.id}}"
                        data-room-title="{{this.title}}"
                      >
                        Удалить
                      </button>
                    </div>
                  </div>
                </article>
              {{/each}}
            </div>
          {{else}}
            <div class="watch-party__empty-state">
              <h3>Пока нет созданных комнат</h3>
              <p>
                Настройте первую комнату выше, и она сразу появится в этом списке.
              </p>
            </div>
          {{/if}}
        </section>
      </div>
    </main>
  </div>
{{/if}}
