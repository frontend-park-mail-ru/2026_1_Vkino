<div class="{{pageClass}}">
  <header id="header"></header>

  <main class="{{mainClass}}">
    {{#if isLoading}}
      <div class="support-tickets__loading" role="status">
        Загружаем обращения...
      </div>
    {{else}}
      <section id="support-tickets-hero" class="{{heroClass}}"></section>

      <div class="support-tickets__layout">
        <aside
          id="support-tickets-sidebar"
          class="{{sidebarClass}}"
        ></aside>

        <section
          id="support-tickets-conversation"
          class="{{chatClass}}"
        ></section>
      </div>
    {{/if}}
  </main>
</div>
