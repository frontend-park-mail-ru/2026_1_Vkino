<div class="page page_catalog">
  <header id="header"></header>

  <main class="catalog-page">
    <section class="catalog-page__hero">
      <header class="poster-carousel__header catalog-page__heading">
        <h1 class="poster-carousel__title catalog-page__title">{{title}}</h1>
      </header>
    </section>

    {{#if cacheMessage}}
      <div class="page-status-banner page-status-banner_warning" role="status">
        <span>{{cacheMessage}}</span>
      </div>
    {{/if}}

    {{#if isLoading}}
      <section class="catalog-page__grid catalog-page__grid--loading">
        {{#each skeletonItems}}
          <div class="catalog-page__skeleton"></div>
        {{/each}}
      </section>
    {{else}}
      {{#if hasError}}
        <div class="catalog-page__banner" role="status">
          <span>{{errorMessage}}</span>
          <button
            type="button"
            class="catalog-page__banner-button"
            data-action="retry-catalog"
          >
            Повторить
          </button>
        </div>
      {{else}}
        {{#if showFavoritesEmpty}}
          <div class="empty-state-card catalog-page__favorites-empty">
            <a
              href="/favorites"
              class="empty-state-icon empty-state-icon--favorites"
              aria-label="Перейти в избранное"
              router-link
            >
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
              </svg>
            </a>
            <p class="empty-state-text">Вы ещё не лайкали фильмы</p>
            <a href="/" class="btn btn-accent btn-sm" router-link>Смотреть каталог</a>
          </div>
        {{else if posterItems.length}}
          <section class="catalog-page__grid">
            {{#each posterItems}}
              <div
                class="catalog-page__card"
                data-catalog-poster="{{slotKey}}"
              ></div>
            {{/each}}
          </section>
        {{else}}
          <section class="catalog-page__empty">
            <h2 class="catalog-page__empty-title">Ничего не найдено</h2>
            <p class="catalog-page__empty-text">
              В этом разделе пока нет карточек для отображения.
            </p>
          </section>
        {{/if}}

        {{#if pagination.shouldRender}}
          <div class="catalog-page__pagination" id="catalog-pagination"></div>
        {{/if}}
      {{/if}}
    {{/if}}
  </main>
</div>
