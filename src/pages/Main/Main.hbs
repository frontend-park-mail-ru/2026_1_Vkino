<header id="header"></header>

<div class="main">
    <div class="side-menu" id="side-menu">
        <button
            class="icon-button"
            type="button"
            data-action="toggle-nav"
            aria-label="Закрыть меню"
        >
            <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="50" height="50" rx="7" fill="#27140B" fill-opacity="0.4"/>
                <path d="M11.4 42L8 38.6L21.6 25L8 11.4L11.4 8L25 21.6L38.6 8L42 11.4L28.4 25L42 38.6L38.6 42L25 28.4L11.4 42Z" fill="#FF571F" fill-opacity="0.8"/>
            </svg>
        </button>

        <div class="side-menu__menu">
            <button type="button" class="side-menu__link" data-content="Новинки">Новинки</button>
            <button type="button" class="side-menu__link" data-content="Фильмы">Фильмы для взрослых</button>
            <button type="button" class="side-menu__link" data-content="Сериалы">Сериалы</button>
            <button type="button" class="side-menu__link" data-content="Мультфильмы">Мультфильмы</button>
        </div>
    </div>

    <div class="main-content" id="main-content">
        <button
            class="icon-button"
            type="button"
            data-action="toggle-nav"
            id="open-icon"
            aria-label="Открыть меню"
        >
            <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="50" height="50" rx="7" fill="#27140B" fill-opacity="0.4"/>
                <path d="M12.25 34.5V31.3333H37.75V34.5H12.25ZM12.25 26.5833V23.4167H37.75V26.5833H12.25ZM12.25 18.6667V15.5H37.75V18.6667H12.25Z" fill="#FF571F" fill-opacity="0.8"/>
            </svg>
        </button>

        <div class="categories-nav">
            <span class="nav-item left">Мультфильмы</span>
            <span class="nav-item center">Фильмы</span>
            <span class="nav-item right">Сериалы</span>
        </div>

        <div class="carousel-section">
            <button class="carousel-icon-button left" type="button" aria-label="Предыдущий слайд">
                <svg width="40" height="54" viewBox="0 0 40 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="40" height="54" rx="7" transform="matrix(-1 0 0 1 40 0)" fill="#F5E8D0" fill-opacity="0.24"/>
                    <path d="M29.0807 44L33 40.9825L14.8386 27L33 13.0175L29.0807 10L7 27L29.0807 44Z" fill="#FF571F" fill-opacity="0.61"/>
                </svg>
            </button>

            <div class="carousel-container">
                <div class="carousel-item">
                    <img class="carousel-image back" src="img/image_10.jpg" alt="Промо 1">
                </div>
                <div class="carousel-item">
                    <img class="carousel-image" src="img/image_11.jpg" alt="Промо 2">
                </div>
                <div class="carousel-item">
                    <img class="carousel-image back" src="img/image_12.jpg" alt="Промо 3">
                </div>
            </div>

            <button class="carousel-icon-button right" type="button" aria-label="Следующий слайд">
                <svg width="40" height="54" viewBox="0 0 40 54" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="40" height="54" rx="7" fill="#F5E8D0" fill-opacity="0.25"/>
                    <path d="M10.9193 44L7 40.9825L25.1614 27L7 13.0175L10.9193 10L33 27L10.9193 44Z" fill="#FF571F" fill-opacity="0.61"/>
                </svg>
            </button>
        </div>

        {{#each selections}}
            <div class="selection-section">
                <h2 class="selection-title">
                    <div class="selection-rectangle"></div>
                    <span></span><span>{{this.title}}&nbsp;<span class="selection-triangle">▸</span></span>
                </h2>
                <div class="scroll-container">
                    <div class="scroll-items">
                        {{#each this.movies}}
                            <img
                                class="movie-poster"
                                data-movie-poster-id="{{this.id}}"
                                src="{{this.img_url}}"
                                draggable="false"
                                alt="{{this.title}}"
                            >
                        {{/each}}
                    </div>
                </div>
            </div>
        {{/each}}
    </div>
</div>