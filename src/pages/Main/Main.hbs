<header id="header"></header>

<div class="main">
  <div class="main-content" id="main-content">
    {{#if cacheMessage}}
      <div class="page-status-banner page-status-banner_warning" role="status">
        <span>{{cacheMessage}}</span>
      </div>
    {{/if}}

    <section
      class="main-hero-slot"
      id="hero-carousel"
      data-scroll-id="Новинки"
    ></section>

    <div class="selection-carousels">
      {{#each selectionEntries}}
        <section
          class="selection-carousel-slot"
          data-scroll-id="{{this.title}}"
        >
          <div
            class="selection-carousel-slot__content"
            data-selection-slot="{{this.slotKey}}"
          ></div>
        </section>
      {{/each}}
    </div>
  </div>
</div>
